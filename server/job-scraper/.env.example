# Copy to .env here AND/OR set the same keys in server/.env (Node loads both).
# Required for Search Jobs → live scrape → Supabase → job listings.

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
LLM_API_KEY=your_llm_api_key
# Optional if you want to use Gemini-specific env vars:
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_FIRST_API_KEY=your_gemini_api_key
