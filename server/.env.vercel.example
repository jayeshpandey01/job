# ==========================================
# VERCEL DEPLOYMENT ENVIRONMENT VARIABLES
# ==========================================
#
# Copy these to your Vercel Project Settings → Environment Variables
# Set scope to: Production + Preview + Development
#
# IMPORTANT: Never commit real values to Git!
#

# ==========================================
# FIREBASE ADMIN SDK (REQUIRED)
# ==========================================
# Get these from Firebase Console → Settings → Service Accounts
# https://console.firebase.google.com/

# Firebase Project ID
# Example: jobfinder-de280
FIREBASE_PROJECT_ID=your_project_id

# Firebase Client Email
# Example: firebase-adminsdk-fbsvc-9b2e4d657d@jobfinder-de280.iam.gserviceaccount.com
FIREBASE_CLIENT_EMAIL=your_client_email@your_project_id.iam.gserviceaccount.com

# Firebase Private Key
# IMPORTANT: Must contain actual newlines (not escaped \n)
# Example: -----BEGIN PRIVATE KEY-----\nMIIEvQI...\n-----END PRIVATE KEY-----\n
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n

# Firebase Private Key ID
# Example: 9b2e4d657d123456789...
FIREBASE_PRIVATE_KEY_ID=your_private_key_id

# Firebase Client ID
# Example: 1234567890
FIREBASE_CLIENT_ID=your_client_id

# Firebase Storage Bucket
# Format: {project-id}.firebasestorage.app
# Example: jobfinder-de280.firebasestorage.app
FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app

# ==========================================
# AI & SERVICES (REQUIRED)
# ==========================================

# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ==========================================
# FRONTEND URLS (REQUIRED)
# ==========================================

# Your Vercel frontend URL and local dev URLs
# Format: https://domain.com (no trailing slash)
# For multiple URLs, separate with comma
FRONTEND_URL=https://joblet-gamma.vercel.app,http://localhost:5173

# ==========================================
# SERVER CONFIGURATION
# ==========================================

# Node environment (automatically set by Vercel)
NODE_ENV=production

# Server port (Vercel sets this automatically)
PORT=3000

# ==========================================
# OPTIONAL: CLOUDINARY (for image uploads)
# ==========================================
# Get from: https://cloudinary.com/

CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET_KEY=your_cloudinary_secret_key

# ==========================================
# OPTIONAL: SUPABASE (for job scraping)
# ==========================================
# Get from: https://supabase.com/

SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ==========================================
# OPTIONAL: SENTRY (for error tracking)
# ==========================================
# Get from: https://sentry.io/

SENTRY_DSN=https://your_sentry_dsn

# ==========================================
# OPTIONAL: GOOGLE CALENDAR
# ==========================================

GOOGLE_CALENDAR_CREDENTIALS=your_google_calendar_credentials

# ==========================================
# HELPFUL: HOW TO SET THESE IN VERCEL
# ==========================================
#
# 1. Go to https://vercel.com/dashboard
# 2. Select your project
# 3. Click Settings (top right)
# 4. Go to Environment Variables (left sidebar)
# 5. Click "Add" for each variable
# 6. Select Environment: Production + Preview + Development
# 7. Paste the value
# 8. Vercel redeploys automatically
#
# For FIREBASE_PRIVATE_KEY with newlines:
# - Copy the entire key from your Firebase JSON
# - Paste it directly into Vercel (it handles newlines correctly)
# - Make sure the value starts with -----BEGIN and ends with -----\n
#
